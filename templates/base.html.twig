<!DOCTYPE html>
<html>
    <head>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
        <title>{% block title %}Cégértékelő{% endblock %}</title>
    </head>
    <body>

        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">

                <a class="navbar-brand" href="{{ url('review.index') }}">Cégértékelő</a>

                <div class="collapse navbar-collapse show">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'review.index' %}active{% endif %}"
                               href="{{ url('review.index') }}">
                                Értékelések
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') == 'review.new' %}active{% endif %}"
                               href="{{ url('review.new') }}">
                                Új értékelés
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'company_stats' %}active{% endif %}"
                               href="{{ url('company_stats.index') }}">
                                Összesített cégstatisztika
                            </a>
                        </li>

                    </ul>
                </div>

            </div>
        </nav>

        <div class="container mt-3">
            {% block body %}{% endblock %}
        </div>

        {{ importmap('app') }}
    </body>
</html>