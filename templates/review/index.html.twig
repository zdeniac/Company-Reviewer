{% extends 'base.html.twig' %}

{% block title %}Értékelések{% endblock %}

{% block body %}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show text-center" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="d-flex justify-content-center mb-4">
        <form method="get" action="{{ path('review.index') }}" class="w-50">

            <div class="input-group">
                <input type="text"
                       name="companyName"
                       value="{{ companyName }}"
                       class="form-control"
                       placeholder="Keresés cégnév alapján...">

                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search"></i>
                </button>

                {% if companyName %}
                    <a href="{{ path('review.index') }}"
                       class="btn btn-outline-secondary">
                        Törlés
                    </a>
                {% endif %}
            </div>

        </form>
    </div>
    
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Cég</th>
                <th>Értékelés</th>
                <th>Vélemény</th>
                <th>Létrehozva</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
        {% for review in reviews %}
            <tr>
                <td>{{ review.companyName }}</td>

                <td>
                    <span class="badge bg-primary">
                        {{ review.rating }}
                    </span>
                </td>

                <td>
                    {{ review.reviewText|u.truncate(20, '...') }}
                </td>

                <td>
                    {{ review.createdAt|date('Y.m.d. H:i') }}
                </td>

                <td class="text-end">
                    <a href="{{ url('review.show', { id: review.id }) }}"
                        class="btn btn-sm btn-primary"
                        title="Megtekintés">
                        <i class="bi bi-eye-fill"></i>
                    </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div>
        {{ render_pagination(pagination, 'review.index', { companyName: companyName }) }}
    </div>
{% endblock %}
